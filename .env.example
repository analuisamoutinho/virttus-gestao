# PostgreSQL (Neon / Supabase / RDS)
DATABASE_URL="postgresql://user:password@localhost:5432/virttus?schema=public"

# Auth.js — gere com: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com > Credentials)
